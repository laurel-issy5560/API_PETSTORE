  "item": [
    {
      "name": "USER",
      "item": [
        {
          "name": "Create list of users",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "\r",
                  "\r",
                  "let firstName  = pm.variables.replaceIn(\"{{$randomFirstName}}\");\r",
                  "pm.environment.set(\"randomFirstName\", firstName);\r",
                  "\r",
                  "let lastName = pm.variables.replaceIn(\"{{$randomLastName}}\");\r",
                  "pm.environment.set(\"randomLastName\", lastName);\r",
                  "\r",
                  "let email = pm.variables.replaceIn(\"{{$randomEmail}}\").toLowerCase();\r",
                  "pm.environment.set(\"randomEmail\", email);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "pm.test(\"status code is 200\",function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"response time is below 2000m/s\", function (){\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"response is an object and not empty\", function(){\r",
                  "    pm.expect(response).to.be.a(\"object\");\r",
                  "    pm.expect(response).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"reponse contains code,type and message\", function () {\r",
                  "    pm.expect(response).to.have.property(\"code\");\r",
                  "    pm.expect(response.code).to.be.a(\"number\");\r",
                  "    pm.expect(response).to.have.property(\"type\");\r",
                  "    pm.expect(response).to.have.property(\"message\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"type and message is a string\", function (){\r",
                  "    pm.expect(response.type).to.be.a(\"string\");\r",
                  "    pm.expect(response.type).to.eql(\"unknown\");\r",
                  "    pm.expect(response.message).to.be.a(\"string\");\r",
                  "    pm.expect(response.message).to.eql(\"ok\")\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"id\": 1,\n    \"username\": \"Havanah_Lesch\",\n    \"firstName\": \"{{randomFirstName}}\",\n    \"lastName\": \"{{randomLastName}}\",\n    \"email\": \"{{randomEmail}}\",\n    \"password\": \"string123\",\n    \"phone\": \"07063945560\",\n    \"userStatus\": 1\n  }\n]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{PST_URL}}/user/createWithList",
              "host": [
                "{{PST_URL}}"
              ],
              "path": [
                "user",
                "createWithList"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get user by username",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"response is an object and not empty\", function(){\r",
                  "    pm.expect(response).to.be.an(\"object\");\r",
                  "    pm.expect(response).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"response contains id, username, firstName,lastName,email, password,phone and userStatus\", function (){\r",
                  "    pm.expect(response).to.have.property(\"id\");\r",
                  "    pm.expect(response.id).to.be.a(\"number\");\r",
                  "    pm.expect(response.id).to.eql(1);\r",
                  "    pm.expect(response).to.have.property(\"username\");\r",
                  "    pm.expect(response.username).to.not.be.empty;\r",
                  "    pm.expect(response.username).to.be.a(\"string\");\r",
                  "    pm.expect(response).to.have.property(\"firstName\");\r",
                  "    pm.expect(response.firstName).to.not.be.empty;\r",
                  "    pm.expect(response.firstName).to.be.a(\"string\");\r",
                  "    pm.expect(response).to.have.property(\"lastName\");\r",
                  "    pm.expect(response.lastName).to.not.be.empty;\r",
                  "    pm.expect(response.lastName).to.be.a(\"string\");\r",
                  "    pm.expect(response).to.have.property(\"email\");\r",
                  "    pm.expect(response.email).to.not.be.empty;\r",
                  "    pm.expect(response.email).to.be.a(\"string\");\r",
                  "    pm.expect(response).to.have.property(\"password\");\r",
                  "    pm.expect(response.password).to.not.be.empty;\r",
                  "    pm.expect(response.password).to.be.a(\"string\");\r",
                  "    pm.expect(response.password).to.eql(\"string123\");\r",
                  "    pm.expect(response).to.have.property(\"phone\");\r",
                  "    pm.expect(response.phone).to.not.be.empty;\r",
                  "    pm.expect(response.phone).to.be.a(\"string\");\r",
                  "    pm.expect(response.phone).to.eql(\"07063945560\");\r",
                  "    pm.expect(response).to.have.property(\"userStatus\");\r",
                  "    pm.expect(response.userStatus).to.be.a(\"number\");\r",
                  "    pm.expect(response.userStatus).to.eql(1);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{PST_URL}}/user/Havanah_Lesch",
